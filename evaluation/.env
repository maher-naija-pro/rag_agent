# ══════════════════════════════════════════════════════════════════════════════
# Evaluation Configuration
# ══════════════════════════════════════════════════════════════════════════════
# These settings control the evaluation module (evaluate.py + generate_testset.py).
# The RAG pipeline itself is configured via rag_agent_pipeline/.env — values
# from that file are loaded first, then these override where needed.

# ── PDF input ────────────────────────────────────────────────────────────────
# Path to the PDF to evaluate against (absolute or relative to project root).
# Used by generate_testset to create questions and by evaluate to detect source.
# EVAL_PDF_PATH=data/eu_ai_act.pdf

# ── RAGAS Judge LLM ─────────────────────────────────────────────────────────
# LLM used by RAGAS to score metrics. This is the "judge" — separate from
# the pipeline LLM that generates answers.
# Tip: use a stronger model here for more reliable evaluation scores.
EVAL_LLM_MODEL=mistral:7b
EVAL_LLM_BASE_URL=http://localhost:11434/v1
EVAL_LLM_API_KEY=ollama
EVAL_LLM_TEMPERATURE=0

# ── RAGAS Judge Embeddings ──────────────────────────────────────────────────
# Embedding model used by metrics that need embeddings (answer_relevancy,
# semantic_similarity, answer_correctness, context_precision_non_llm, etc.)
EVAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Testset Generation ──────────────────────────────────────────────────────
# Number of synthetic test samples to generate.
EVAL_TESTSET_SIZE=10

# Chunking settings for testset generation (how the PDF is split before
# generating questions). These are independent of the pipeline chunking.
EVAL_CHUNK_SIZE=800
EVAL_CHUNK_OVERLAP=150

# ── Output ──────────────────────────────────────────────────────────────────
# Directory for evaluation results (scores.json, evaluation_details.csv, etc.)
# EVAL_OUTPUT_DIR=evaluation/output


# ══════════════════════════════════════════════════════════════════════════════
# RAGAS Metrics
# ══════════════════════════════════════════════════════════════════════════════
# Comma-separated list of metrics to run. Pick any combination from below.
#
# ── Core RAG (LLM-as-judge) ────────────────────────────────────────────────
#   faithfulness              — Is the answer grounded in the retrieved context? (no reference needed)
#   faithfulness_hhem         — Faithfulness scored with HHEM (Hughes Hallucination Eval Model)
#   answer_relevancy          — Does the answer address the question? (needs embeddings)
#   context_precision         — Are retrieved chunks relevant? Ranked. (no reference needed)
#   context_precision_ref     — Context precision with reference answer
#   context_precision_non_llm — Context precision using embeddings instead of LLM
#   context_recall            — Did retrieval find all needed info? (needs reference)
#   context_recall_non_llm    — Context recall using embeddings instead of LLM
#   context_entity_recall     — Entity-level recall in retrieved context
#   noise_sensitivity         — Is the answer robust to irrelevant context?
#
# ── Answer Quality ─────────────────────────────────────────────────────────
#   answer_correctness        — Overall correctness vs reference (factual + semantic)
#   factual_correctness       — Claim-level precision/recall vs reference
#   semantic_similarity       — Embedding cosine similarity vs reference (no LLM needed)
#
# ── Custom / Rubric-Based ──────────────────────────────────────────────────
#   simple_criteria           — LLM scores on simple criteria
#   summarization             — Summarization quality (keyphrase coverage)
#
# ── Traditional NLP (no LLM needed) ────────────────────────────────────────
#   bleu                      — BLEU n-gram precision vs reference
#   rouge                     — ROUGE n-gram overlap vs reference
#   exact_match               — Exact string match vs reference
#   string_presence           — Substring presence check
#   string_similarity         — Levenshtein / Hamming / Jaro distance vs reference
#
EVAL_METRICS=faithfulness,faithfulness_hhem,answer_relevancy,context_precision,context_precision_ref,context_precision_non_llm,context_recall,context_recall_non_llm,context_entity_recall,noise_sensitivity,answer_correctness,factual_correctness,semantic_similarity,simple_criteria,summarization,bleu,rouge,exact_match,string_presence,string_similarity


# ══════════════════════════════════════════════════════════════════════════════
# Aspect Critics (custom binary pass/fail)
# ══════════════════════════════════════════════════════════════════════════════
# Define custom evaluation aspects. Each EVAL_ASPECT_<NAME> creates an
# AspectCritic that scores 0 (fail) or 1 (pass) per sample.
#
# Format: EVAL_ASPECT_<NAME>=<natural language definition>
#
# Examples (uncomment to enable):
# EVAL_ASPECT_HARMFULNESS=Does the response contain harmful, toxic, or dangerous content?
# EVAL_ASPECT_CONCISENESS=Is the response concise and free of unnecessary repetition or filler?
# EVAL_ASPECT_COHERENCE=Is the response logically coherent and well-structured?
# EVAL_ASPECT_CITATION=Does the response cite specific page numbers from the source document?
# EVAL_ASPECT_COMPLETENESS=Does the response fully address all parts of the question?
# EVAL_ASPECT_POLITENESS=Is the response polite and professional in tone?


# ══════════════════════════════════════════════════════════════════════════════
# Rubric-Based Scoring (custom 1-5 scale)
# ══════════════════════════════════════════════════════════════════════════════
# Define a scoring rubric with descriptions for each level (1=worst, 5=best).
# All 5 levels must be defined for the rubric to activate.
#
# Format: EVAL_RUBRIC_<N>=<description>
#
# Example (uncomment all 5 to enable):
# EVAL_RUBRIC_1=Completely wrong, irrelevant, or harmful response
# EVAL_RUBRIC_2=Partially correct but missing key information or contains errors
# EVAL_RUBRIC_3=Correct answer but poorly explained or missing citations
# EVAL_RUBRIC_4=Correct, well-explained answer with proper citations
# EVAL_RUBRIC_5=Perfect answer: accurate, well-cited, concise, and directly addresses the question
